# ── MongoDB Atlas ──────────────────────────────────────────────
# Replace with your Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_user:your_password@your-cluster.mongodb.net/deadlinr?retryWrites=true&w=majority

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
